meta {
  name: Untitled
  type: http
  seq: 1
}

post {
  url: {{url}}/api/registro
  body: json
  auth: inherit
}

body:json {
  {
    "nombre": "Prueba",
    "apellido": "Usuario",
    "email": "test@ejemplo.com",
    "contrasena": "123456"
  }
}

assert {
  res.status: eq 201
  res.body.mensaje: eq "Usuario registrado con éxito"
}

settings {
  encodeUrl: true
  timeout: 0
}
